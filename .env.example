# MailFlow — Environment variables
# Copy to .env and fill in your values. Never commit .env.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mailflow:mailflow@localhost:5432/mailflow
# For self-hosted SQLite mode:
# DATABASE_URL=sqlite+aiosqlite:///./mailflow.db

# ── Redis (ARQ queue) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (Better Auth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── OAuth — Microsoft 365 ─────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ── OAuth — Gmail ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LLM defaults (LiteLLM) ───────────────────────────────────────────────────
# Users can override per workspace. These are server-side defaults.
LITELLM_DEFAULT_MODEL=ollama/llama3.1:8b
LITELLM_DEFAULT_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ── Workers ───────────────────────────────────────────────────────────────────
WORKER_CYCLE_INTERVAL_SECONDS=300
WORKER_MAX_EMAILS_PER_CYCLE=20
